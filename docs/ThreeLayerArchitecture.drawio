        </mxCell>
        <mxCell id="chatflow" value="&lt;b&gt;Chat RAG Flow&lt;/b&gt;&lt;br&gt;Question -&amp;gt; save message -&amp;gt; history -&amp;gt; rewrite/fuzzy match -&amp;gt; embedding -&amp;gt; retrieve top chunks -&amp;gt; answer + citations" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#D8E4F0;dashed=1;fontSize=14;fontColor=#3C536B;arcSize=8;spacing=12;" vertex="1" parent="1">
