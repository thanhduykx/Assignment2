@page "{id:guid}"
@using BusinessObjects
@model PresentationLayer.Pages.Home.SubjectDocumentsModel
@{
    ViewData["Title"] = Model.Subject.DisplayName;
    ViewData["UseRblShell"] = true;
    ViewData["ActiveNav"] = "documents";
    ViewData["ShellTitle"] = "Chi ti&#7871;t m&#244;n h&#7885;c";
    ViewData["ShellTitleI18n"] = "documents.shellTitle";

    string FormatBytes(long bytes)
    {
        var units = new[] { "B", "KB", "MB", "GB", "TB" };
        var size = Math.Max(0, bytes);
        var unitIndex = 0;
        var value = (double)size;
        while (value >= 1024 && unitIndex < units.Length - 1)
        {
            value /= 1024;
            unitIndex++;
        }

        return unitIndex == 0 ? $"{size} {units[unitIndex]}" : $"{value:0.##} {units[unitIndex]}";
    }

    string PersonLabel(string name, string fallback)
    {
        return string.IsNullOrWhiteSpace(name) ? fallback : name.Trim();
    }

    string StatusLabel(IndexedDocument document)
    {
        return document.Status switch
        {
            DocumentIndexStatus.Indexed => "Indexed",
            DocumentIndexStatus.Processing => "Processing",
            DocumentIndexStatus.Failed => "Failed",
            _ => string.IsNullOrWhiteSpace(document.Status) ? "Unknown" : document.Status
        };
    }

    string StatusTitle(IndexedDocument document)
    {
        if (document.Status == DocumentIndexStatus.Failed && !string.IsNullOrWhiteSpace(document.IndexError))
        {
            return document.IndexError;
        }

        if (document.Status == DocumentIndexStatus.Indexed && document.IndexedAt.HasValue)
        {
            return $"Indexed at {document.IndexedAt.Value.LocalDateTime:yyyy-MM-dd HH:mm}";
        }

        return StatusLabel(document);
    }
}

<section class="ops-page ops-documents-page ops-subject-detail-page">
    <a class="ops-back-link" asp-page="/Home/Index">
        <span class="material-symbols-outlined" aria-hidden="true">arrow_back</span>
        Quay l&#7841;i danh s&#225;ch m&#244;n
    </a>

    <header class="ops-page-header">
        <div>
            <span class="ops-eyebrow">Course documents</span>
            <h1>@Model.Subject.DisplayName</h1>
            <p>@(string.IsNullOrWhiteSpace(Model.Subject.Description) ? "Qu&#7843;n l&#253; ch&#432;&#417;ng, file v&#224; link b&#224;i gi&#7843;ng c&#7911;a m&#244;n n&#224;y." : Model.Subject.Description)</p>
        </div>
        <div class="ops-subject-header-actions">
            <span class="ops-chip">@Model.Subject.DocumentCount t&#224;i li&#7879;u</span>
            <span class="ops-chip">@Model.Subject.Chapters.Count ch&#432;&#417;ng</span>
            @if (!string.IsNullOrWhiteSpace(Model.Subject.OwnerName))
            {
                <span class="ops-chip">Owner: @PersonLabel(Model.Subject.OwnerName, "Unassigned")</span>
            }
        </div>
    </header>

    @if (TempData["Success"] is string success)
    {
        <div class="rbl-alert is-success">@success</div>
    }
    @if (TempData["Error"] is string error)
    {
        <div class="rbl-alert is-error">@error</div>
    }
    @if (!string.IsNullOrWhiteSpace(Model.LoadErrorMessage))
    {
        <div class="rbl-alert is-error">@Model.LoadErrorMessage</div>
    }

    <section class="ops-subject-detail-grid">
        @if (Model.IsAdmin && Model.IsRealCatalogSubject)
        {
            <section class="ops-panel ops-subject-manage-panel">
                <div class="ops-panel-head">
                    <div>
                        <span class="ops-eyebrow">Subject</span>
                        <h2>S&#7917;a th&#244;ng tin m&#244;n</h2>
                    </div>
                </div>
                <div class="ops-row-actions">
                    <form asp-page-handler="SaveSubject" method="post" class="ops-subject-edit-form">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="Id" value="@Model.Subject.SubjectId" />
                        <label class="ops-field">
                            <span>M&#227; m&#244;n</span>
                            <input name="Code" value="@Model.Subject.Code" />
                        </label>
                        <label class="ops-field">
                            <span>M&#244; t&#7843;</span>
                            <input name="Description" value="@Model.Subject.Description" />
                        </label>
                        <button type="submit" class="ops-button ops-button--primary">L&#432;u m&#244;n</button>
                    </form>
                    <form asp-page-handler="DeleteSubject" method="post" data-confirm="Xoa mon nay va toan bo chuong ben trong? Thao tac nay khong the hoan tac.">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="ops-button ops-button--secondary">X&#243;a m&#244;n</button>
                    </form>
                </div>
            </section>
        }

        <form asp-page-handler="SaveChapter" method="post" class="ops-panel ops-subject-manage-panel">
            @Html.AntiForgeryToken()
            <input type="hidden" name="SubjectId" value="@Model.Subject.SubjectId" />
            <div class="ops-panel-head">
                <div>
                    <span class="ops-eyebrow">Chapter</span>
                    <h2>Th&#234;m ch&#432;&#417;ng/m&#7909;c</h2>
                </div>
            </div>
            <label class="ops-field">
                <span>T&#234;n ch&#432;&#417;ng/m&#7909;c</span>
                <input name="Title" placeholder="VD: Chapter 1 / Muc 1.1" required />
            </label>
            <label class="ops-field">
                <span>Th&#7913; t&#7921;</span>
                <input name="SortOrder" type="number" value="@(Model.Subject.Chapters.Count + 1)" />
            </label>
            <button type="submit" class="ops-button ops-button--primary">Th&#234;m ch&#432;&#417;ng</button>
        </form>

        @if (Model.IsLecturer)
        {
            <form asp-page-handler="Upload" method="post" enctype="multipart/form-data" class="ops-panel ops-subject-manage-panel ops-subject-upload-panel">
                @Html.AntiForgeryToken()
                <input type="hidden" name="Language" value="vi" data-language-field />
                <input type="hidden" name="Subject" value="@Model.Subject.DisplayName" />
                <div class="ops-panel-head">
                    <div>
                        <span class="ops-eyebrow">Upload</span>
                        <h2>Th&#234;m t&#224;i li&#7879;u</h2>
                    </div>
                </div>
                <label class="ops-field">
                    <span>Ch&#432;&#417;ng/m&#7909;c</span>
                    <input name="Chapter" placeholder="VD: Chapter 1 / Muc 1.1" required />
                </label>
                <label class="ops-field">
                    <span>File t&#224;i li&#7879;u</span>
                    <input name="File" type="file" accept=".pdf,.docx,.pptx,.txt" />
                </label>
                <label class="ops-field">
                    <span>Ho&#7863;c URL b&#224;i gi&#7843;ng</span>
                    <input name="SourceUrl" type="url" placeholder="https://example.com/lecture" />
                </label>
                <button type="submit" class="ops-button ops-button--primary">
                    <span class="material-symbols-outlined" aria-hidden="true">upload_file</span>
                    Index t&#224;i li&#7879;u
                </button>
            </form>
        }
    </section>

    <section class="ops-panel">
        <div class="ops-panel-head">
            <div>
                <span class="ops-eyebrow">Documents</span>
                <h2>Ch&#432;&#417;ng v&#224; t&#224;i li&#7879;u</h2>
            </div>
        </div>

        @if (Model.Subject.Chapters.Count == 0)
        {
            <div class="ops-empty">
                <strong>M&#244;n n&#224;y ch&#432;a c&#243; ch&#432;&#417;ng/m&#7909;c.</strong>
                <p>Th&#234;m ch&#432;&#417;ng tr&#432;&#7899;c, sau &#273;&#243; upload t&#224;i li&#7879;u v&#224;o &#273;&#250;ng m&#7909;c.</p>
            </div>
        }
        else
        {
            <div class="ops-folder-chapter-list">
                @foreach (var chapter in Model.Subject.Chapters.OrderBy(item => item.SortOrder).ThenBy(item => item.Title))
                {
                    <details class="ops-folder-chapter" open>
                        <summary class="ops-folder-chapter-summary">
                            <span class="material-symbols-outlined" aria-hidden="true">folder_open</span>
                            <span class="ops-folder-main">
                                <strong>@chapter.Title</strong>
                                <small>@chapter.Documents.Count t&#224;i li&#7879;u</small>
                            </span>
                        </summary>

                        <div class="ops-folder-chapter-body">
                            <div class="ops-folder-toolbar">
                                <form asp-page-handler="SaveChapter" method="post" class="ops-inline-edit ops-folder-chapter-edit">
                                    @Html.AntiForgeryToken()
                                    @if (chapter.ChapterId.HasValue)
                                    {
                                        <input type="hidden" name="Id" value="@chapter.ChapterId" />
                                    }
                                    <input type="hidden" name="SubjectId" value="@Model.Subject.SubjectId" />
                                    <input name="Title" value="@chapter.Title" required />
                                    <input name="SortOrder" type="number" value="@chapter.SortOrder" />
                                    <button type="submit" class="ops-mini-button">Update</button>
                                </form>
                                @if (chapter.ChapterId.HasValue)
                                {
                                    <form asp-page-handler="DeleteChapter" method="post" data-confirm="Xoa chuong/muc nay? Thao tac nay khong the hoan tac.">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="chapterId" value="@chapter.ChapterId" />
                                        <button type="submit" class="ops-mini-button ops-mini-button--danger">Delete</button>
                                    </form>
                                }
                            </div>

                            @if (Model.IsLecturer)
                            {
                                <form asp-page-handler="Upload" method="post" enctype="multipart/form-data" class="ops-tree-upload">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="Language" value="vi" data-language-field />
                                    <input type="hidden" name="Subject" value="@Model.Subject.DisplayName" />
                                    <input type="hidden" name="Chapter" value="@chapter.Title" />

                                    <label class="ops-field">
                                        <span>Th&#234;m file v&#224;o @chapter.Title</span>
                                        <input name="File" type="file" accept=".pdf,.docx,.pptx,.txt" />
                                    </label>
                                    <label class="ops-field">
                                        <span>Ho&#7863;c URL b&#224;i gi&#7843;ng</span>
                                        <input name="SourceUrl" type="url" placeholder="https://example.com/lecture" />
                                    </label>
                                    <button type="submit" class="ops-button ops-button--primary">
                                        <span class="material-symbols-outlined" aria-hidden="true">upload_file</span>
                                        Th&#234;m t&#224;i li&#7879;u
                                    </button>
                                </form>
                            }

                            @if (chapter.Documents.Count == 0)
                            {
                                <p class="ops-muted">Ch&#432;a c&#243; t&#224;i li&#7879;u trong ch&#432;&#417;ng/m&#7909;c n&#224;y.</p>
                            }
                            else
                            {
                                <div class="ops-tree-document-list">
                                    @foreach (var document in chapter.Documents.OrderByDescending(item => item.UploadedAt))
                                    {
                                        <div class="ops-tree-document-row" data-document-id="@document.Id" data-document-status-value="@document.Status" data-document-size-label="@FormatBytes(document.FileSizeBytes)">
                                            <span class="material-symbols-outlined" aria-hidden="true">description</span>
                                            <div class="ops-tree-document-main">
                                                <strong title="@document.FileName">@document.FileName</strong>
                                                <small data-document-tree-meta>@StatusLabel(document) - @document.ChunkCount chunks - @FormatBytes(document.FileSizeBytes)</small>
                                            </div>
                                            <div class="ops-row-actions" data-document-actions>
                                                @if (document.Status == DocumentIndexStatus.Indexed)
                                                {
                                                    <button type="button" class="ops-mini-button" data-document-preview-action data-document-preview-label="Xem" data-document-preview-url="/Home/DocumentPreview/@document.Id">Xem</button>
                                                }
                                                else
                                                {
                                                    <button type="button" class="ops-mini-button" data-document-preview-action data-document-preview-label="Xem" disabled title="@StatusTitle(document)">Xem</button>
                                                }
                                                @if (Model.CanManageDocumentAction(document, Model.Subject))
                                                {
                                                    <a class="ops-mini-button" asp-page="/Home/EditDocument" asp-route-id="@document.Id">S&#7917;a</a>
                                                    <form asp-page-handler="ReindexDocument" method="post" data-confirm="Re-index tai lieu nay?">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="documentId" value="@document.Id" />
                                                    <button type="submit" class="ops-mini-button">Re-index</button>
                                                </form>
                                                <form asp-page-handler="DeleteDocument" method="post" data-confirm="Xoa tai lieu nay khoi kho index? Thao tac nay khong the hoan tac.">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="documentId" value="@document.Id" />
                                                    <button type="submit" class="ops-mini-button ops-mini-button--danger">X&#243;a</button>
                                                </form>
                                                }
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    </details>
                }
            </div>
        }
    </section>

    <div id="documentPreviewModal" class="rbl-document-preview-modal" aria-hidden="true">
        <div class="rbl-document-preview-backdrop" data-document-preview-close></div>
        <section class="rbl-document-preview-dialog" role="dialog" aria-modal="true" aria-labelledby="documentPreviewTitle">
            <header class="rbl-document-preview-header">
                <div>
                    <span class="rbl-section-label">Indexed content</span>
                    <h2 id="documentPreviewTitle">T&#224;i li&#7879;u</h2>
                    <p id="documentPreviewMeta"></p>
                </div>
                <button type="button" class="rbl-icon-button" aria-label="Close preview" data-document-preview-close>
                    <span class="material-symbols-outlined" aria-hidden="true">close</span>
                </button>
            </header>
            <div id="documentPreviewBody" class="rbl-document-preview-body">
                <p class="rbl-catalog-muted">&#272;ang t&#7843;i n&#7897;i dung &#273;&#227; index...</p>
            </div>
        </section>
    </div>
</section>
