@page
@model PresentationLayer.Pages.Admin.IndexModel
@{
    ViewData["Title"] = "User roles";
    ViewData["UseRblShell"] = true;
    ViewData["ActiveNav"] = "admin";
    ViewData["ShellTitle"] = "User roles";
}

<section class="rbl-panel rbl-document-table-panel">
    <div class="rbl-panel-header">
        <div>
            <span class="rbl-section-label">Admin</span>
            <h2>User role management</h2>
        </div>
        <span class="rbl-table-meta">@Model.Users.Count users</span>
    </div>

    @if (TempData["Success"] is string success)
    {
        <div class="rbl-alert is-success">@success</div>
    }
    @if (TempData["Error"] is string error)
    {
        <div class="rbl-alert is-error">@error</div>
    }

    <section class="rbl-admin-create-user">
        <div>
            <span class="rbl-section-label">Create account</span>
            <h3>Register a user</h3>
        </div>
        <form asp-page-handler="CreateUser" method="post" class="rbl-admin-create-form">
            @Html.AntiForgeryToken()
            <label class="rbl-field">
                <span>Full name</span>
                <input name="FullName" maxlength="120" autocomplete="name" />
            </label>
            <label class="rbl-field">
                <span>Email</span>
                <input name="Email" type="email" autocomplete="email" />
            </label>
            <label class="rbl-field">
                <span>Password</span>
                <input name="Password" type="password" minlength="8" autocomplete="new-password" />
            </label>
            <label class="rbl-field">
                <span>Role</span>
                <select name="Role">
                    @foreach (var role in Model.Roles)
                    {
                        if (role.Equals(PresentationLayer.Security.AppRoles.Student, StringComparison.OrdinalIgnoreCase))
                        {
                            <option value="@role" selected>@role</option>
                        }
                        else
                        {
                            <option value="@role">@role</option>
                        }
                    }
                </select>
            </label>
            <button type="submit" class="rbl-submit-button">
                <span class="material-symbols-outlined" aria-hidden="true">person_add</span>
                Create
            </button>
        </form>
    </section>

    <section class="rbl-admin-create-user">
        <div>
            <span class="rbl-section-label">Create subject</span>
            <h3>Add a course subject</h3>
        </div>
        <form asp-page-handler="CreateSubject" method="post" class="rbl-admin-create-form rbl-admin-subject-form">
            @Html.AntiForgeryToken()
            <label class="rbl-field">
                <span>Subject code</span>
                <input name="Code" maxlength="32" placeholder="IOT102" autocomplete="off" />
            </label>
            <label class="rbl-field">
                <span>Subject name</span>
                <input name="Name" maxlength="255" placeholder="Internet of Things" autocomplete="off" />
            </label>
            <label class="rbl-field">
                <span>Description</span>
                <input name="Description" maxlength="1000" placeholder="Optional" autocomplete="off" />
            </label>
            <button type="submit" class="rbl-submit-button">
                <span class="material-symbols-outlined" aria-hidden="true">library_add</span>
                Create subject
            </button>
        </form>
    </section>

    @if (Model.Users.Count == 0)
    {
        <div class="rbl-empty-state compact">
            <strong>No users yet.</strong>
            <p>The first registered account will become Admin automatically.</p>
        </div>
    }
    else
    {
        <div class="rbl-table-wrap">
            <table class="rbl-table rbl-user-role-table">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Provider</th>
                        <th>Created</th>
                        <th>Role</th>
                        <th>Subjects</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var user in Model.Users)
                {
                    <tr>
                        <td class="rbl-user-name-cell">
                            <form asp-page-handler="UpdateName" method="post" class="rbl-user-name-form">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="UserId" value="@user.Id" />
                                <label class="rbl-field rbl-user-name-field">
                                    <span class="visually-hidden">Full name</span>
                                    <input name="FullName" value="@user.FullName" maxlength="120" autocomplete="name" />
                                </label>
                                <button type="submit" class="rbl-small-button rbl-small-button--primary">Save</button>
                            </form>
                        </td>
                        <td>@user.Email</td>
                        <td>@user.Provider</td>
                        <td>@user.CreatedAt.LocalDateTime.ToString("yyyy-MM-dd HH:mm")</td>
                        <td class="rbl-role-cell">
                            <form asp-page-handler="UpdateRole" method="post" class="rbl-role-form">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="UserId" value="@user.Id" />
                                <label class="rbl-field rbl-role-field">
                                    <span class="visually-hidden">Role</span>
                                    <select name="Role" disabled="@user.IsLastAdmin">
                                        @foreach (var role in Model.Roles)
                                        {
                                            if (role.Equals(user.Role, StringComparison.OrdinalIgnoreCase))
                                            {
                                                <option value="@role" selected>@role</option>
                                            }
                                            else
                                            {
                                                <option value="@role">@role</option>
                                            }
                                        }
                                    </select>
                                </label>
                                <button type="submit" class="rbl-small-button rbl-small-button--primary" disabled="@user.IsLastAdmin">Save</button>
                            </form>
                        </td>
                        <td class="rbl-lecturer-subject-cell">
                            @if (user.Role == PresentationLayer.Security.AppRoles.Lecturer)
                            {
                                <div class="rbl-lecturer-subjects">
                                    @if (user.AssignedSubjects.Count == 0)
                                    {
                                        <span class="rbl-muted-chip">No owned subjects</span>
                                    }
                                    else
                                    {
                                        foreach (var subject in user.AssignedSubjects)
                                        {
                                            <span class="rbl-subject-owner-chip">@subject</span>
                                        }
                                    }
                                </div>
                                <form asp-page-handler="AssignLecturerSubject" method="post" class="rbl-lecturer-subject-form">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="UserId" value="@user.Id" />
                                    <label class="rbl-field rbl-lecturer-subject-field">
                                        <span class="visually-hidden">Subject</span>
                                        <select name="SubjectId" disabled="@(Model.SubjectOptions.Count == 0)">
                                            @if (Model.SubjectOptions.Count == 0)
                                            {
                                                <option value="">No subjects</option>
                                            }
                                            else
                                            {
                                                foreach (var subject in Model.SubjectOptions)
                                                {
                                                    var ownerLabel = string.IsNullOrWhiteSpace(subject.OwnerName)
                                                        ? "Unassigned"
                                                        : $"Owner: {subject.OwnerName}";
                                                    <option value="@subject.Id">@subject.DisplayName (@ownerLabel)</option>
                                                }
                                            }
                                        </select>
                                    </label>
                                    <button type="submit" class="rbl-small-button rbl-small-button--primary" disabled="@(Model.SubjectOptions.Count == 0)">Assign</button>
                                </form>
                            }
                            else if (user.Role == PresentationLayer.Security.AppRoles.Student)
                            {
                                <span class="rbl-subject-owner-chip">All indexed documents</span>
                            }
                            else
                            {
                                <span class="rbl-muted-chip">Not applicable</span>
                            }
                        </td>
                        <td class="rbl-role-status-cell">
                            @if (user.IsLastAdmin)
                            {
                                <span class="rbl-status is-success">Last admin</span>
                            }
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</section>
