@page
@model PresentationLayer.Pages.Admin.IndexModel
@{
    ViewData["Title"] = "Người dùng / Users";
    ViewData["UseRblShell"] = true;
    ViewData["ActiveNav"] = "admin";
    ViewData["ShellTitle"] = "Người dùng / Users";

    var users = Model.Users
        .OrderBy(user => user.Role)
        .ThenBy(user => user.FullName)
        .ThenBy(user => user.Email)
        .ToList();
    var hasActiveFilters = !string.IsNullOrWhiteSpace(Model.Query)
        || !string.IsNullOrWhiteSpace(Model.RoleFilter);
    var unassignedSubjects = Model.SubjectOptions
        .Where(subject => !subject.OwnerUserId.HasValue)
        .OrderBy(subject => subject.DisplayName)
        .ToList();

    string DisplayName(PresentationLayer.Models.AdminUserRowViewModel user)
    {
        return string.IsNullOrWhiteSpace(user.FullName) ? user.Email : user.FullName;
    }

    string Initials(PresentationLayer.Models.AdminUserRowViewModel user)
    {
        var source = DisplayName(user).Trim();
        if (string.IsNullOrWhiteSpace(source))
        {
            return "U";
        }

        var parts = source.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length >= 2)
        {
            return $"{parts[0][0]}{parts[^1][0]}".ToUpperInvariant();
        }

        return source[..1].ToUpperInvariant();
    }

}

<section class="ops-page ops-admin-page">
    <header class="ops-page-header">
        <div>
            <span class="ops-eyebrow">Access control</span>
            <h1>Người dùng / User roles</h1>
            <p>Quản lý tài khoản, vai trò và phân công môn phụ trách cho giảng viên.</p>
        </div>
    </header>

    @if (TempData["Success"] is string success)
    {
        <div class="rbl-alert is-success">@success</div>
    }
    @if (TempData["Error"] is string error)
    {
        <div class="rbl-alert is-error">@error</div>
    }

    <section class="ops-kpi-grid ops-admin-kpis" aria-label="User metrics">
        <article class="ops-kpi">
            <span>Total users</span>
            <strong>@Model.TotalUserCount</strong>
            <small>@users.Count shown</small>
        </article>
        <article class="ops-kpi">
            <span>Admins</span>
            <strong>@Model.AdminUserCount</strong>
            <small>Full system access</small>
        </article>
        <article class="ops-kpi">
            <span>Lecturers</span>
            <strong>@Model.LecturerUserCount</strong>
            <small>Manage assigned subjects</small>
        </article>
        <article class="ops-kpi">
            <span>Students</span>
            <strong>@Model.StudentUserCount</strong>
            <small>Read and chat access</small>
        </article>
        <article class="ops-kpi">
            <span>Subjects</span>
            <strong>@Model.SubjectCount</strong>
            <small>@Model.AssignedSubjectCount assigned</small>
        </article>
    </section>

    <div class="ops-admin-layout">
        <section class="ops-panel ops-admin-main">
            <div class="ops-panel-head">
                <div>
                    <span class="ops-eyebrow">Directory</span>
                    <h2>Bảng người dùng / User table</h2>
                </div>
                <span class="ops-panel-note">@users.Count/@Model.TotalUserCount users</span>
            </div>

            <form asp-page="/Admin/Index" method="get" class="ops-filter-bar ops-admin-filter">
                <label class="ops-field ops-field--search">
                    <span>Search / Tìm kiếm</span>
                    <input name="q" value="@Model.Query" placeholder="Name, email, provider, subject..." />
                </label>
                <label class="ops-field">
                    <span>Role / Vai trò</span>
                    <select name="roleFilter">
                        @if (string.IsNullOrWhiteSpace(Model.RoleFilter))
                        {
                            <option value="" selected>All roles</option>
                        }
                        else
                        {
                            <option value="">All roles</option>
                        }
                        @foreach (var role in Model.Roles)
                        {
                            if (role.Equals(Model.RoleFilter, StringComparison.OrdinalIgnoreCase))
                            {
                                <option value="@role" selected>@role</option>
                            }
                            else
                            {
                                <option value="@role">@role</option>
                            }
                        }
                    </select>
                </label>
                <button type="submit" class="ops-button ops-button--secondary">Filter</button>
                @if (hasActiveFilters)
                {
                    <a class="ops-button ops-button--ghost" asp-page="/Admin/Index">Clear</a>
                }
            </form>

            @if (users.Count == 0)
            {
                <div class="ops-empty">
                    <strong>No matching users.</strong>
                    <p>Clear filters or create a new account from the command panel.</p>
                </div>
            }
            else
            {
                <div class="ops-table-wrap">
                    <table class="ops-table ops-user-table">
                        <thead>
                            <tr>
                                <th>User</th>
                                <th>Provider</th>
                                <th>Created</th>
                                <th>Role / Vai trò</th>
                                <th>Subjects</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var user in users)
                        {
                            <tr>
                                <td data-label="User">
                                    <div class="ops-user-cell">
                                        <span class="ops-avatar">@Initials(user)</span>
                                        <div class="ops-user-identity">
                                            <strong>@DisplayName(user)</strong>
                                            <small>@user.Email</small>
                                        </div>
                                    </div>
                                </td>
                                <td data-label="Provider">
                                    <span class="ops-chip">@user.Provider</span>
                                </td>
                                <td data-label="Created">
                                    <span>@user.CreatedAt.LocalDateTime.ToString("yyyy-MM-dd HH:mm")</span>
                                </td>
                                <td data-label="Role / Vai trò">
                                    <form asp-page-handler="UpdateRole" method="post" class="ops-role-form" data-admin-role-update-form>
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="UserId" value="@user.Id" />
                                        <select
                                            name="Role"
                                            disabled="@user.IsLastAdmin"
                                            data-admin-role-update-select
                                            data-admin-role-user="@user.Email"
                                            title="Đổi role sẽ hỏi xác nhận và tự lưu">
                                            @foreach (var role in Model.Roles)
                                            {
                                                if (role.Equals(user.Role, StringComparison.OrdinalIgnoreCase))
                                                {
                                                    <option value="@role" selected>@role</option>
                                                }
                                                else
                                                {
                                                    <option value="@role">@role</option>
                                                }
                                            }
                                        </select>
                                    </form>
                                </td>
                                <td data-label="Subjects">
                                    @if (user.Role == PresentationLayer.Security.AppRoles.Lecturer)
                                    {
                                        <div class="ops-chip-list">
                                            @if (user.AssignedSubjects.Count == 0)
                                            {
                                                <span class="ops-chip ops-chip--muted">No subjects set</span>
                                            }
                                            else
                                            {
                                                foreach (var subject in user.AssignedSubjects)
                                                {
                                                    <span class="ops-chip">@subject</span>
                                                }
                                            }
                                        </div>
                                    }
                                    else if (user.Role == PresentationLayer.Security.AppRoles.Student)
                                    {
                                        <span class="ops-chip">All indexed documents</span>
                                    }
                                    else
                                    {
                                        <span class="ops-chip ops-chip--muted">Not applicable</span>
                                    }
                                </td>
                                <td data-label="Actions">
                                    @{
                                        var deleteDisabled = user.IsLastAdmin
                                            || user.IsCurrentUser
                                            || user.Role != PresentationLayer.Security.AppRoles.Student;
                                        var deleteTitle = user.IsCurrentUser
                                            ? "Cannot delete your own active account"
                                            : user.IsLastAdmin
                                                ? "Cannot delete the last admin"
                                                : user.Role != PresentationLayer.Security.AppRoles.Student
                                                    ? "Set role to Student before deleting"
                                                    : "Delete user";
                                    }
                                    <form asp-page-handler="DeleteUser" method="post" class="ops-danger-form" data-confirm="Xóa người dùng này? Thao tác này không thể hoàn tác.">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="UserId" value="@user.Id" />
                                        <button
                                            type="submit"
                                            class="ops-mini-button ops-mini-button--danger"
                                            disabled="@deleteDisabled"
                                            title="@deleteTitle">
                                            Delete
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            }
        </section>

        <aside class="ops-command-rail" aria-label="Admin commands">
            <section class="ops-panel ops-command-card">
                <span class="ops-eyebrow">Create account</span>
                <h2>Thêm user</h2>
                <form asp-page-handler="CreateUser" method="post" class="ops-stacked-form" data-admin-create-user-form>
                    @Html.AntiForgeryToken()
                    <label class="ops-field">
                        <span>Full name</span>
                        <input name="FullName" maxlength="120" autocomplete="name" />
                    </label>
                    <label class="ops-field">
                        <span>Email</span>
                        <input name="Email" type="email" autocomplete="email" />
                    </label>
                    <label class="ops-field">
                        <span>Password</span>
                        <input name="Password" type="password" minlength="8" autocomplete="new-password" />
                    </label>
                    <label class="ops-field">
                        <span>Role</span>
                        <select name="Role" data-admin-role-select>
                            @foreach (var role in Model.Roles)
                            {
                                if (role.Equals(PresentationLayer.Security.AppRoles.Student, StringComparison.OrdinalIgnoreCase))
                                {
                                    <option value="@role" selected>@role</option>
                                }
                                else
                                {
                                    <option value="@role">@role</option>
                                }
                            }
                        </select>
                    </label>
                    <fieldset class="ops-field ops-subject-picker" data-lecturer-subject-picker>
                        <legend>Subjects for lecturer</legend>
                        @if (unassignedSubjects.Count == 0)
                        {
                            <span class="ops-muted">No unassigned subjects</span>
                        }
                        else
                        {
                            <div class="ops-subject-options">
                                @foreach (var subject in unassignedSubjects)
                                {
                                    <label class="ops-subject-option">
                                        <input type="checkbox" name="SubjectIds" value="@subject.Id" />
                                        <span>@subject.DisplayName</span>
                                    </label>
                                }
                            </div>
                        }
                    </fieldset>
                    <button type="submit" class="ops-button ops-button--primary">
                        <span class="material-symbols-outlined" aria-hidden="true">person_add</span>
                        Create user
                    </button>
                </form>
            </section>

            <section class="ops-panel ops-command-card">
                <span class="ops-eyebrow">Create subject</span>
                <h2>Thêm môn</h2>
                <form asp-page-handler="CreateSubject" method="post" class="ops-stacked-form">
                    @Html.AntiForgeryToken()
                    <label class="ops-field">
                        <span>Subject code</span>
                        <input name="Code" maxlength="32" placeholder="IOT102" autocomplete="off" />
                    </label>
                    <label class="ops-field">
                        <span>Subject name (optional)</span>
                        <input name="Name" maxlength="255" placeholder="Defaults to subject code" autocomplete="off" />
                    </label>
                    <label class="ops-field">
                        <span>Description</span>
                        <input name="Description" maxlength="1000" placeholder="Optional" autocomplete="off" />
                    </label>
                    <button type="submit" class="ops-button ops-button--primary">
                        <span class="material-symbols-outlined" aria-hidden="true">library_add</span>
                        Create subject
                    </button>
                </form>
            </section>
        </aside>
    </div>
</section>
