@model PresentationLayer.Models.ChatIndexViewModel
@{
    ViewData["Title"] = "Chatbot";
    ViewData["UseRblShell"] = true;
    ViewData["ActiveNav"] = "chat";
    ViewData["ShellTitle"] = "Chatbot tài liệu";
    ViewData["HideAssistantLauncher"] = true;

    var suggestedQuestions = new[]
    {
        new { En = "How many credits does DBA103 have?", Vi = "Môn DBA103 có bao nhiêu tín chỉ?" },
        new { En = "What is DBA103 about?", Vi = "DBA103 là môn gì?" },
        new { En = "What should students learn in DBA103?", Vi = "Sinh viên sẽ học những gì trong DBA103?" },
        new { En = "What is the time allocation of DBA103?", Vi = "Thời lượng học của DBA103 là bao nhiêu?" }
    };

    var primaryDocument = Model.Documents
        .OrderByDescending(document =>
            document.FileName.StartsWith("FLM-", StringComparison.OrdinalIgnoreCase)
            || document.FileName.Contains("Syllabus-11835", StringComparison.OrdinalIgnoreCase)
                ? 3
                : document.Subject.Contains("DBA103", StringComparison.OrdinalIgnoreCase)
                  || document.Chapter.Contains("Syllabus 11835", StringComparison.OrdinalIgnoreCase)
                    ? 2
                    : 1)
        .ThenByDescending(document => document.UploadedAt)
        .FirstOrDefault();
    var primarySubject = string.IsNullOrWhiteSpace(primaryDocument?.Subject) ? "this course" : primaryDocument.Subject;
    var primaryChapter = string.IsNullOrWhiteSpace(primaryDocument?.Chapter) ? "the current chapter" : primaryDocument.Chapter;
    var relatedQuestions = primaryDocument is null
        ? Array.Empty<(string En, string Vi)>()
        : new[]
        {
            ($"What is {primarySubject} about?", $"{primarySubject} là môn gì?"),
            ($"How many credits does {primarySubject} have?", $"{primarySubject} có bao nhiêu tín chỉ?"),
            ($"What are the main contents of {primarySubject}?", $"Nội dung chính của {primarySubject} gồm những gì?"),
            ($"What should students practice in {primaryChapter}?", $"Sinh viên cần luyện tập gì trong {primaryChapter}?")
        };
}

<section class="rbl-chat-page">
    <main class="rbl-chat-main" aria-label="Document chat" data-i18n-aria-label="chat.mainAria">
        <header class="rbl-chat-header">
            <div>
                <span class="rbl-section-label">Course assistant</span>
                <h1>Nhập môn AI</h1>
                <p>Hỏi đáp dựa trên tài liệu đã index. Nếu dữ liệu không đủ, chatbot phải báo thiếu nguồn thay vì đoán.</p>
            </div>
            <span class="rbl-status is-success">@Model.Documents.Count tài liệu sẵn sàng</span>
        </header>

        <div id="chatMessages" class="chat-messages codex-chat-messages rbl-chat-messages">
            <div class="chat-empty-state rbl-chat-empty">
                <span class="rbl-bot-mark">AI</span>
                <h3 data-i18n="chat.emptyTitle">Bắt đầu bằng một câu hỏi cụ thể</h3>
                <p data-i18n="chat.emptyText">Chọn gợi ý bên dưới hoặc nhập câu hỏi về tài liệu môn học.</p>
                <div class="suggestion-grid rbl-suggestion-grid" aria-label="Question suggestions" data-i18n-aria-label="chat.suggestionsAria">
                    @foreach (var question in suggestedQuestions)
                    {
                        <button type="button" class="suggestion-chip" data-question="@question.En" data-question-en="@question.En" data-question-vi="@question.Vi">@question.En</button>
                    }
                </div>
            </div>
            <div class="message assistant">
                <div class="bubble" data-i18n="chat.welcome">Bạn có thể hỏi về nội dung tài liệu đã upload. Câu trả lời sẽ ưu tiên ngắn gọn và có nguồn.</div>
            </div>
        </div>

        <form id="chatForm" class="chat-form codex-chat-form rbl-chat-form">
            @if (relatedQuestions.Length > 0)
            {
                <div class="chat-related-strip rbl-related-strip" aria-label="Related questions" data-i18n-aria-label="chat.relatedAria">
                    <span data-i18n="chat.relatedLabel">Related questions</span>
                    <div class="chat-related-list">
                        @foreach (var question in relatedQuestions)
                        {
                            <button type="button" class="related-question-chip" data-question="@question.Item1" data-question-en="@question.Item1" data-question-vi="@question.Item2">@question.Item1</button>
                        }
                    </div>
                </div>
            }
            <textarea id="questionInput" rows="2" placeholder="Example: How many credits does DBA103 have?" data-i18n-placeholder="chat.placeholder"></textarea>
            <button type="submit" class="rbl-submit-button" data-i18n="chat.send">
                <span class="material-symbols-outlined" aria-hidden="true">send</span>
                Send
            </button>
        </form>
    </main>

    <aside class="rbl-session-panel" aria-label="Chat session history" data-i18n-aria-label="chat.sessionsAria">
        <div class="rbl-session-actions">
            <button id="newSessionButton" type="button" class="rbl-submit-button" data-i18n="chat.newSession">
                <span class="material-symbols-outlined" aria-hidden="true">add</span>
                New session
            </button>
        </div>

        <div class="rbl-session-header">
            <strong data-i18n="chat.history">Lịch sử hội thoại</strong>
            <span><span id="sessionCount">@Model.ChatSessions.Count</span> sessions</span>
        </div>

        <div id="chatSessionList" class="chat-session-list rbl-session-list">
            @if (Model.ChatSessions.Count == 0)
            {
                <p class="session-empty" data-i18n="chat.noSessions">No sessions yet.</p>
            }
            else
            {
                foreach (var session in Model.ChatSessions)
                {
                    var firstQuestion = session.Messages.FirstOrDefault(message => message.Role == "user")?.Content?.Trim();
                    var title = string.IsNullOrWhiteSpace(firstQuestion)
                        ? "Session without a question"
                        : firstQuestion.Length <= 56 ? firstQuestion : $"{firstQuestion[..56]}...";

                    <button type="button" class="chat-session-item" data-session-id="@session.Id">
                        <span>@title</span>
                        <small>@session.UpdatedAt.ToLocalTime().ToString("dd/MM HH:mm") / @session.Messages.Count messages</small>
                    </button>
                }
            }
        </div>

        <div class="rbl-session-storage">
            <span>Storage</span>
            <strong>@Model.Documents.Sum(item => item.ChunkCount) chunks</strong>
            <div class="rbl-meter">
                <span style="width:@Math.Min(100, Model.Documents.Count * 4)%"></span>
            </div>
        </div>
    </aside>
</section>
