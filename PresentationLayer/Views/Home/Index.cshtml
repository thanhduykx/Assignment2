@model PresentationLayer.Models.HomeIndexViewModel
@{
    ViewData["Title"] = "Kho tài liệu";
    ViewData["UseRblShell"] = true;
    ViewData["ActiveNav"] = "documents";
    ViewData["ShellTitle"] = "Kho tài liệu";

    var documents = Model.Documents.OrderByDescending(item => item.UploadedAt).ToList();
    var totalDocuments = documents.Count;
    var indexedDocuments = totalDocuments;
    var totalChunks = documents.Sum(item => item.ChunkCount);
    var subjectOptions = documents
        .Select(document => document.Subject)
        .Where(subject => !string.IsNullOrWhiteSpace(subject))
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .OrderBy(subject => subject)
        .ToList();
    var chapterOptions = documents
        .Select(document => document.Chapter)
        .Where(chapter => !string.IsNullOrWhiteSpace(chapter))
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .OrderBy(chapter => chapter)
        .ToList();
}

<section class="rbl-documents-page">
    <div class="rbl-page-heading">
        <div>
            <h1>Quản lý kho tài liệu</h1>
            <p>Upload tài liệu học tập, trích xuất nội dung và index để chatbot trả lời có nguồn.</p>
        </div>
        <a class="rbl-secondary-button" asp-controller="Home" asp-action="Chat">
            <span class="material-symbols-outlined" aria-hidden="true">chat</span>
            Open chat
        </a>
    </div>

    @if (TempData["Success"] is string success)
    {
        <div class="rbl-alert is-success">@success</div>
    }
    @if (TempData["Error"] is string error)
    {
        <div class="rbl-alert is-error">@error</div>
    }

    <div class="rbl-documents-grid">
        <section class="rbl-upload-panel" id="documents">
            <div class="rbl-panel-header">
                <div>
                    <span class="rbl-section-label">Upload</span>
                    <h2>Kéo thả tài liệu vào đây</h2>
                </div>
            </div>

            <form asp-action="Upload" method="post" enctype="multipart/form-data" class="rbl-upload-form">
                @Html.AntiForgeryToken()
                <input type="hidden" name="Language" value="vi" data-language-field />

                <div class="rbl-form-grid">
                    <label class="rbl-field">
                        <span>Subject</span>
                        <input name="Subject" list="subjectOptions" placeholder="DBA103 - Traditional musical instrument" />
                    </label>
                    <label class="rbl-field">
                        <span>Chapter</span>
                        <input name="Chapter" list="chapterOptions" placeholder="Syllabus 11835 hoặc Chapter 1" />
                    </label>
                </div>

                <datalist id="subjectOptions">
                    @foreach (var subject in subjectOptions)
                    {
                        <option value="@subject"></option>
                    }
                </datalist>
                <datalist id="chapterOptions">
                    @foreach (var chapter in chapterOptions)
                    {
                        <option value="@chapter"></option>
                    }
                </datalist>

                <label id="documentDropzone" class="rbl-dropzone dropzone" for="documentFileInput">
                    <input id="documentFileInput" name="File" type="file" accept=".pdf,.docx,.pptx,.txt" />
                    <span class="material-symbols-outlined" aria-hidden="true">cloud_upload</span>
                    <strong>Chọn tệp hoặc kéo thả vào đây</strong>
                    <small id="documentFileName" data-default-en="Supports PDF, DOCX, PPTX, TXT" data-default-vi="Hỗ trợ PDF, DOCX, PPTX, TXT">Hỗ trợ PDF, DOCX, PPTX, TXT</small>
                </label>

                <div class="rbl-divider"><span>or</span></div>

                <label class="rbl-field">
                    <span>Lecture page URL</span>
                    <input name="SourceUrl" type="url" placeholder="https://example.com/lecture" />
                    <small>Trang SPA/React/Vue sẽ được render trước khi trích xuất DOM.</small>
                </label>

                <button type="submit" class="rbl-submit-button">
                    <span class="material-symbols-outlined" aria-hidden="true">upload_file</span>
                    Upload and index
                </button>
            </form>
        </section>

        <aside class="rbl-storage-panel">
            <div>
                <span class="rbl-section-label">Storage</span>
                <h2>Tình trạng lưu trữ</h2>
            </div>
            <div class="rbl-storage-meter">
                <span style="width:@Math.Min(100, totalDocuments * 4)%"></span>
            </div>
            <div class="rbl-storage-stats">
                <article>
                    <span>Tài liệu</span>
                    <strong>@totalDocuments</strong>
                </article>
                <article>
                    <span>Chunks</span>
                    <strong>@totalChunks</strong>
                </article>
                <article>
                    <span>Indexed</span>
                    <strong>@indexedDocuments</strong>
                </article>
            </div>
        </aside>
    </div>

    <section class="rbl-panel rbl-document-table-panel">
        <div class="rbl-panel-header">
            <div>
                <span class="rbl-section-label">Documents</span>
                <h2>Danh sách tài liệu</h2>
            </div>
            <span class="rbl-table-meta">Hiển thị @totalDocuments tài liệu</span>
        </div>

        @if (documents.Count == 0)
        {
            <div class="rbl-empty-state compact">
                <strong>Chưa có tài liệu.</strong>
                <p>Upload giáo trình hoặc URL bài giảng để bắt đầu hỏi đáp theo nguồn.</p>
            </div>
        }
        else
        {
            <div class="rbl-table-wrap">
                <table class="rbl-table">
                    <thead>
                        <tr>
                            <th>Tên file</th>
                            <th>Subject</th>
                            <th>Chapter</th>
                            <th>Trạng thái</th>
                            <th>Ngày upload</th>
                            <th>Chunks</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var document in documents)
                    {
                        <tr>
                            <td>
                                <strong>@document.FileName</strong>
                                <span>@document.ContentType</span>
                            </td>
                            <td>@document.Subject</td>
                            <td>@document.Chapter</td>
                            <td><span class="rbl-status is-success">Đã Index</span></td>
                            <td>@document.UploadedAt.LocalDateTime.ToString("yyyy-MM-dd HH:mm")</td>
                            <td class="rbl-mono">@document.ChunkCount</td>
                            <td class="rbl-table-actions">
                                <a class="rbl-small-button" asp-controller="Home" asp-action="ViewDocument" asp-route-id="@document.Id" target="_blank" rel="noopener">View</a>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </section>
</section>
