@using DataAccessLayer
@model PresentationLayer.Models.HomeIndexViewModel
@{
    ViewData["Title"] = "Kho tài liệu";
    ViewData["UseRblShell"] = true;
    ViewData["ActiveNav"] = "documents";
    ViewData["ShellTitle"] = "Kho tài liệu";
    ViewData["ShellTitleI18n"] = "documents.shellTitle";

    var documents = Model.Documents.OrderByDescending(item => item.UploadedAt).ToList();
    var courseCatalog = Model.CourseCatalog.OrderBy(item => item.Code).ToList();
    var lecturerOptions = Model.LecturerOptions.OrderBy(item => item.FullName).ThenBy(item => item.Email).ToList();
    var isAdmin = Model.IsAdmin;
    var totalDocuments = Model.TotalDocumentCount > 0 ? Model.TotalDocumentCount : documents.Count;
    var visibleDocuments = documents.Count;
    var totalChunks = Model.TotalChunkCount > 0 ? Model.TotalChunkCount : documents.Sum(item => item.ChunkCount);
    var totalUploadedBytes = Model.TotalUploadedBytes > 0 ? Model.TotalUploadedBytes : documents.Sum(item => item.FileSizeBytes);
    var averageChunks = Model.AverageChunksPerIndexedDocument <= 0 ? 0 : Model.AverageChunksPerIndexedDocument;
    var documentSubjectOptions = Model.DocumentSubjectOptions
        .Where(subject => !string.IsNullOrWhiteSpace(subject))
        .OrderBy(subject => subject)
        .ToList();
    var subjectOptions = courseCatalog
        .Select(subject => subject.DisplayName)
        .Concat(documentSubjectOptions)
        .Where(subject => !string.IsNullOrWhiteSpace(subject))
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .OrderBy(subject => subject)
        .ToList();
    var chapterOptions = courseCatalog.SelectMany(subject => subject.Chapters)
        .Select(chapter => chapter.Title)
        .Concat(Model.DocumentChapterOptions)
        .Where(chapter => !string.IsNullOrWhiteSpace(chapter))
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .OrderBy(chapter => chapter)
        .ToList();
    var canManageDocuments = Model.IsAdmin || Model.IsLecturer;

    string FormatBytes(long bytes)
    {
        var units = new[] { "B", "KB", "MB", "GB", "TB" };
        var size = Math.Max(0, bytes);
        var unitIndex = 0;
        var value = (double)size;
        while (value >= 1024 && unitIndex < units.Length - 1)
        {
            value /= 1024;
            unitIndex++;
        }

        return unitIndex == 0 ? $"{size} {units[unitIndex]}" : $"{value:0.##} {units[unitIndex]}";
    }

    string PersonLabel(string name, string fallback)
    {
        return string.IsNullOrWhiteSpace(name) ? fallback : name.Trim();
    }

    string StatusClass(IndexedDocument document)
    {
        return document.Status switch
        {
            DocumentIndexStatus.Indexed => "is-success",
            DocumentIndexStatus.Processing => "is-running",
            DocumentIndexStatus.Failed => "is-error",
            _ => "is-muted"
        };
    }

    string StatusLabel(IndexedDocument document)
    {
        return document.Status switch
        {
            DocumentIndexStatus.Indexed => "Indexed",
            DocumentIndexStatus.Processing => "Processing",
            DocumentIndexStatus.Failed => "Failed",
            _ => string.IsNullOrWhiteSpace(document.Status) ? "Unknown" : document.Status
        };
    }

    string StatusTitle(IndexedDocument document)
    {
        if (document.Status == DocumentIndexStatus.Failed && !string.IsNullOrWhiteSpace(document.IndexError))
        {
            return document.IndexError;
        }

        if (document.Status == DocumentIndexStatus.Indexed && document.IndexedAt.HasValue)
        {
            return $"Indexed at {document.IndexedAt.Value.LocalDateTime:yyyy-MM-dd HH:mm}";
        }

        return StatusLabel(document);
    }
}

<section class="rbl-documents-page">
    <div class="rbl-page-heading">
        <div>
            @if (canManageDocuments)
            {
                <h1 data-i18n="documents.manageTitle">Quản lý kho tài liệu</h1>
                <p data-i18n="documents.manageSubtitle">Upload tài liệu học tập, trích xuất nội dung và index để chatbot trả lời có nguồn.</p>
            }
            else
            {
                <h1>Kho tài liệu</h1>
                <p>Xem các tài liệu đã được giảng viên upload và index.</p>
            }
        </div>
        <a class="rbl-secondary-button" asp-controller="Home" asp-action="Chat">
            <span class="material-symbols-outlined" aria-hidden="true">chat</span>
            <span data-i18n="documents.openChat">Open chat</span>
        </a>
    </div>

    @if (TempData["Success"] is string success)
    {
        <div class="rbl-alert is-success">@success</div>
    }
    @if (TempData["Error"] is string error)
    {
        <div class="rbl-alert is-error">@error</div>
    }

    @if (canManageDocuments)
    {
    <div class="rbl-documents-grid">
        @if (canManageDocuments)
        {
            <section class="rbl-upload-panel" id="documents">
                <div class="rbl-panel-header">
                    <div>
                        <span class="rbl-section-label" data-i18n="documents.uploadKicker">Upload</span>
                        <h2 data-i18n="documents.dropTitle">Kéo thả tài liệu vào đây</h2>
                    </div>
                </div>

                <form asp-action="Upload" method="post" enctype="multipart/form-data" class="rbl-upload-form">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="Language" value="vi" data-language-field />

                    <div class="rbl-form-grid">
                        <label class="rbl-field">
                            <span data-i18n="documents.subject">Subject</span>
                            <input name="Subject" list="subjectOptions" placeholder="Mã môn - Tên môn" />
                        </label>
                        <label class="rbl-field">
                            <span data-i18n="documents.chapter">Chapter</span>
                            <input name="Chapter" list="chapterOptions" placeholder="Chương 1 hoặc Tuần 1" />
                        </label>
                    </div>

                    <datalist id="subjectOptions">
                        @foreach (var subject in subjectOptions)
                        {
                            <option value="@subject"></option>
                        }
                    </datalist>
                    <datalist id="chapterOptions">
                        @foreach (var chapter in chapterOptions)
                        {
                            <option value="@chapter"></option>
                        }
                    </datalist>

                    <label id="documentDropzone" class="rbl-dropzone dropzone" for="documentFileInput">
                        <input id="documentFileInput" name="File" type="file" accept=".pdf,.docx,.pptx,.txt" />
                        <span class="material-symbols-outlined" aria-hidden="true">cloud_upload</span>
                        <strong data-i18n="documents.chooseFile">Chọn tệp hoặc kéo thả vào đây</strong>
                        <small id="documentFileName" data-default-en="Supports PDF, DOCX, PPTX, TXT" data-default-vi="Hỗ trợ PDF, DOCX, PPTX, TXT">Hỗ trợ PDF, DOCX, PPTX, TXT</small>
                    </label>

                    <div class="rbl-divider"><span data-i18n="documents.or">or</span></div>

                    <label class="rbl-field">
                        <span data-i18n="documents.url">Lecture page URL</span>
                        <input name="SourceUrl" type="url" placeholder="https://example.com/lecture" />
                        <small data-i18n="documents.urlRenderHint">Trang SPA/React/Vue sẽ được render trước khi trích xuất DOM.</small>
                    </label>

                    <button type="submit" class="rbl-submit-button">
                        <span class="material-symbols-outlined" aria-hidden="true">upload_file</span>
                        <span data-i18n="documents.submit">Upload and index</span>
                    </button>
                </form>
            </section>
        }

        <aside class="rbl-storage-panel">
            <div>
                <span class="rbl-section-label" data-i18n="documents.uploadedSize">Dung lượng đã upload</span>
                <h2>@FormatBytes(totalUploadedBytes)</h2>
            </div>
            <div class="rbl-storage-stats">
                <article>
                    <span data-i18n="documents.totalUploaded">Tổng đã upload</span>
                    <strong>@FormatBytes(totalUploadedBytes)</strong>
                </article>
                <article>
                    <span data-i18n="documents.statsDocuments">Tài liệu</span>
                    <strong>@totalDocuments</strong>
                </article>
                <article>
                    <span>Chunks</span>
                    <strong>@totalChunks</strong>
                </article>
                <article>
                    <span>Indexed</span>
                    <strong>@Model.IndexedDocumentCount</strong>
                </article>
                <article>
                    <span>Processing</span>
                    <strong>@Model.ProcessingDocumentCount</strong>
                </article>
                <article>
                    <span>Failed</span>
                    <strong>@Model.FailedDocumentCount</strong>
                </article>
                <article>
                    <span>Avg chunks/indexed doc</span>
                    <strong>@averageChunks.ToString("0.#")</strong>
                </article>
            </div>
        </aside>
    </div>
    }

    @if (canManageDocuments)
    {
    <section class="rbl-panel rbl-catalog-panel">
        <div class="rbl-panel-header rbl-catalog-header">
            <div>
                <span class="rbl-section-label">Danh mục môn học</span>
                <h2>Quản lý môn học và chương</h2>
                <p class="rbl-catalog-help">Danh mục này tự thêm môn/chương từ Subject và Chapter của tài liệu đã upload.</p>
            </div>
            <span class="rbl-table-meta">@courseCatalog.Count môn học</span>
        </div>

        <div class="rbl-catalog-create-grid">
            @if (isAdmin)
            {
                <form asp-action="SaveSubject" method="post" class="rbl-catalog-form">
                    @Html.AntiForgeryToken()
                    <div class="rbl-catalog-form-header">
                        <h3>Thêm môn học</h3>
                        <p>Tạo danh mục môn để dùng lại khi upload và lọc tài liệu.</p>
                    </div>
                    <div class="rbl-catalog-fields rbl-catalog-fields--subject">
                        <label class="rbl-field">
                            <span>Mã môn</span>
                            <input name="Code" placeholder="Mã môn" />
                        </label>
                        <label class="rbl-field">
                            <span>Tên môn</span>
                            <input name="Name" placeholder="Nhạc cụ truyền thống - Đàn Bầu" />
                        </label>
                        <label class="rbl-field">
                            <span>Mô tả</span>
                            <input name="Description" placeholder="Mô tả ngắn" />
                        </label>
                        <label class="rbl-field">
                            <span>Giảng viên phụ trách</span>
                            <select name="OwnerUserId">
                                <option value="">Chưa phân công</option>
                                @foreach (var lecturer in lecturerOptions)
                                {
                                    <option value="@lecturer.Id">@lecturer.DisplayName</option>
                                }
                            </select>
                        </label>
                        <button type="submit" class="rbl-small-button rbl-small-button--primary">Lưu môn</button>
                    </div>
                </form>
            }

            <form asp-action="SaveChapter" method="post" class="rbl-catalog-form">
                @Html.AntiForgeryToken()
                <div class="rbl-catalog-form-header">
                    <h3>Thêm chương</h3>
                    <p>Chương giúp gắn tài liệu vào đúng phần nội dung học.</p>
                </div>
                <div class="rbl-catalog-fields rbl-catalog-fields--chapter">
                    <label class="rbl-field">
                        <span>Môn học</span>
                        <select name="SubjectId">
                            @foreach (var subject in courseCatalog)
                            {
                                <option value="@subject.Id">@subject.DisplayName</option>
                            }
                        </select>
                    </label>
                    <label class="rbl-field">
                        <span>Tên chương</span>
                        <input name="Title" placeholder="Chương 1 hoặc Tuần 1" />
                    </label>
                    <label class="rbl-field">
                        <span>Thứ tự</span>
                        <input name="SortOrder" type="number" value="1" />
                    </label>
                    <button type="submit" class="rbl-small-button rbl-small-button--primary">Lưu chương</button>
                </div>
            </form>
        </div>

        @if (courseCatalog.Count == 0)
        {
            <div class="rbl-empty-state compact">
                <strong>Chưa có danh mục môn học.</strong>
                <p>Tạo môn học trước, sau đó thêm chương để upload tài liệu theo danh mục chuẩn.</p>
            </div>
        }
        else
        {
            <div class="rbl-catalog-list">
                    @foreach (var subject in courseCatalog)
                    {
                        <article class="rbl-catalog-subject">
                            <div class="rbl-catalog-subject-head">
                                <div>
                                    <span class="rbl-catalog-code">@subject.Code</span>
                                    <h3>@subject.Name</h3>
                                    <p>@(string.IsNullOrWhiteSpace(subject.Description) ? "Chưa có mô tả." : subject.Description)</p>
                                    <span class="rbl-owner-chip" title="@subject.OwnerEmail">Phụ trách: @PersonLabel(subject.OwnerName, "Chưa phân công")</span>
                                </div>
                                @if (isAdmin)
                                {
                                    <form asp-action="DeleteSubject" method="post" class="rbl-catalog-delete">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@subject.Id" />
                                        <button type="submit" class="rbl-small-button rbl-small-button--danger">Xóa môn</button>
                                    </form>
                                }
                            </div>

                            @if (isAdmin)
                            {
                                <form asp-action="SaveSubject" method="post" class="rbl-catalog-edit">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="Id" value="@subject.Id" />
                                    <label class="rbl-field">
                                        <span>Mã môn</span>
                                        <input name="Code" value="@subject.Code" />
                                    </label>
                                    <label class="rbl-field">
                                        <span>Tên môn</span>
                                        <input name="Name" value="@subject.Name" />
                                    </label>
                                    <label class="rbl-field">
                                        <span>Mô tả</span>
                                        <input name="Description" value="@subject.Description" />
                                    </label>
                                    <label class="rbl-field">
                                        <span>Giảng viên phụ trách</span>
                                        <select name="OwnerUserId">
                                            @if (!subject.OwnerUserId.HasValue)
                                            {
                                                <option value="" selected>Chưa phân công</option>
                                            }
                                            else
                                            {
                                                <option value="">Chưa phân công</option>
                                            }
                                            @foreach (var lecturer in lecturerOptions)
                                            {
                                                if (subject.OwnerUserId == lecturer.Id)
                                                {
                                                    <option value="@lecturer.Id" selected>@lecturer.DisplayName</option>
                                                }
                                                else
                                                {
                                                    <option value="@lecturer.Id">@lecturer.DisplayName</option>
                                                }
                                            }
                                        </select>
                                    </label>
                                    <button type="submit" class="rbl-small-button">Cập nhật môn</button>
                                </form>
                            }

                            <div class="rbl-chapter-section">
                                <div class="rbl-chapter-section-head">
                                    <span>Chương</span>
                                    <strong>@subject.Chapters.Count chương</strong>
                                </div>
                                @if (subject.Chapters.Count == 0)
                                {
                                    <p class="rbl-catalog-muted">Môn này chưa có chương.</p>
                                }
                                else
                                {
                                    @foreach (var chapter in subject.Chapters)
                                    {
                                        <div class="rbl-chapter-row">
                                            <form asp-action="SaveChapter" method="post" class="rbl-chapter-edit">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="Id" value="@chapter.Id" />
                                                <input type="hidden" name="SubjectId" value="@subject.Id" />
                                                <label class="rbl-field rbl-chapter-title">
                                                    <span>Tên chương</span>
                                                    <input name="Title" value="@chapter.Title" />
                                                </label>
                                                <label class="rbl-field rbl-chapter-order">
                                                    <span>Thứ tự</span>
                                                    <input name="SortOrder" type="number" value="@chapter.SortOrder" />
                                                </label>
                                                <button type="submit" class="rbl-small-button">Cập nhật</button>
                                            </form>
                                            <form asp-action="DeleteChapter" method="post" class="rbl-chapter-delete">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@chapter.Id" />
                                                <button type="submit" class="rbl-small-button rbl-small-button--danger">Xóa</button>
                                            </form>
                                        </div>
                                    }
                                }
                            </div>
                        </article>
                    }
            </div>
        }
    </section>
    }

    <section class="rbl-panel rbl-document-table-panel">
        <div class="rbl-panel-header">
            <div>
                <span class="rbl-section-label">Documents</span>
                <h2 data-i18n="documents.documentList">Danh sách tài liệu</h2>
            </div>
            <span class="rbl-table-meta"><span data-i18n="documents.showing">Hiển thị</span> @visibleDocuments/@totalDocuments <span data-i18n="documents.statsDocuments">tài liệu</span></span>
        </div>

        @if (subjectOptions.Count > 0)
        {
            <form asp-action="Index" method="get" class="rbl-document-filter">
                <label class="rbl-field">
                    <span>Lọc theo môn</span>
                    <select name="subjectFilter">
                        @if (string.IsNullOrWhiteSpace(Model.SubjectFilter))
                        {
                            <option value="" selected>Tất cả môn</option>
                        }
                        else
                        {
                            <option value="">Tất cả môn</option>
                        }

                        @foreach (var subject in subjectOptions)
                        {
                            if (subject.Equals(Model.SubjectFilter, StringComparison.OrdinalIgnoreCase))
                            {
                                <option value="@subject" selected>@subject</option>
                            }
                            else
                            {
                                <option value="@subject">@subject</option>
                            }
                        }
                    </select>
                </label>
                <button type="submit" class="rbl-small-button rbl-small-button--primary">Lọc</button>
                @if (!string.IsNullOrWhiteSpace(Model.SubjectFilter))
                {
                    <a class="rbl-small-button" asp-controller="Home" asp-action="Index">Bỏ lọc</a>
                }
            </form>
        }

        @if (documents.Count == 0)
        {
            <div class="rbl-empty-state compact">
                <strong data-i18n="documents.emptyTitle">Chưa có tài liệu.</strong>
                <p data-i18n="documents.emptyHint">Upload giáo trình hoặc URL bài giảng để bắt đầu hỏi đáp theo nguồn.</p>
            </div>
        }
        else
        {
            <div class="rbl-document-card-grid">
                @foreach (var document in documents)
                {
                    <article class="rbl-document-card">
                        <div class="rbl-document-card-head">
                            <span class="rbl-document-file-icon material-symbols-outlined" aria-hidden="true">description</span>
                            <span class="rbl-status @StatusClass(document)" title="@StatusTitle(document)">@StatusLabel(document)</span>
                        </div>

                        <div class="rbl-document-card-body">
                            <h3 title="@document.FileName">@document.FileName</h3>
                            <p title="@document.Subject">@document.Subject</p>
                            <span title="@document.Chapter">@document.Chapter</span>
                        </div>

                        <div class="rbl-document-card-meta">
                            <span>
                                <span class="material-symbols-outlined" aria-hidden="true">data_object</span>
                                @document.ChunkCount chunks
                            </span>
                            <span>
                                <span class="material-symbols-outlined" aria-hidden="true">hard_drive</span>
                                @FormatBytes(document.FileSizeBytes)
                            </span>
                            <span class="rbl-document-meta-full">
                                <span class="material-symbols-outlined" aria-hidden="true">schedule</span>
                                @document.UploadedAt.LocalDateTime.ToString("yyyy-MM-dd HH:mm")
                            </span>
                            <span class="rbl-document-meta-full" title="@document.UploadedByEmail">
                                <span class="material-symbols-outlined" aria-hidden="true">person</span>
                                <strong>Được up bởi:</strong> @PersonLabel(document.UploadedByName, "Không rõ")
                            </span>
                        </div>

                        <div class="rbl-document-card-actions rbl-document-actions">
                                @if (document.Status == DocumentIndexStatus.Indexed)
                                {
                                    <button type="button" class="rbl-small-button" data-document-preview-url="@Url.Action("DocumentPreview", "Home", new { id = document.Id })" data-i18n="documents.view">Xem</button>
                                }
                                else
                                {
                                    <button type="button" class="rbl-small-button" disabled title="@StatusTitle(document)" data-i18n="documents.view">Xem</button>
                                }
                                @if (canManageDocuments)
                                {
                                    <a class="rbl-small-button" asp-controller="Home" asp-action="EditDocument" asp-route-id="@document.Id">Sửa</a>
                                    <form asp-action="DeleteDocument" method="post" onsubmit="return confirm('Xóa tài liệu này khỏi kho index?');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@document.Id" />
                                        <button type="submit" class="rbl-small-button rbl-small-button--danger">Xóa</button>
                                    </form>
                                }
                        </div>
                    </article>
                    }
            </div>
        }
    </section>

    <div id="documentPreviewModal" class="rbl-document-preview-modal" aria-hidden="true">
        <div class="rbl-document-preview-backdrop" data-document-preview-close></div>
        <section class="rbl-document-preview-dialog" role="dialog" aria-modal="true" aria-labelledby="documentPreviewTitle">
            <header class="rbl-document-preview-header">
                <div>
                    <span class="rbl-section-label">Indexed content</span>
                    <h2 id="documentPreviewTitle">Tài liệu</h2>
                    <p id="documentPreviewMeta"></p>
                </div>
                <button type="button" class="rbl-icon-button" aria-label="Close preview" data-document-preview-close>
                    <span class="material-symbols-outlined" aria-hidden="true">close</span>
                </button>
            </header>
            <div id="documentPreviewBody" class="rbl-document-preview-body">
                <p class="rbl-catalog-muted">Đang tải nội dung đã index...</p>
            </div>
        </section>
    </div>
</section>
